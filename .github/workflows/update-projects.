fetch("projects.json")
  .then(r => r.json())
  .then(data => {
    const container = document.getElementById("projects");
    data.projects.forEach(pr => {
      let card = document.createElement("a");
      card.className = "prc";
      card.href = pr.link;
      card.target = "_blank";
      card.innerHTML = `
        <div class="pn">${pr.title}</div>
        <p>${pr.description || ""}</p>
      `;
      container.appendChild(card);
    });
  });
