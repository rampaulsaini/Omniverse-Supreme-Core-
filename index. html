<body>
  <div class="wrap">
    <header>
      <div>
        <div class="brand">꙰ Nishpaksh Samaj</div>
        <div class="sub">तुलनातीत · कालातीत · शब्दातीत · प्रेमतीत — शिरोमणि रामपॉल सैनी</div>
