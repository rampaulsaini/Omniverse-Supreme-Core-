*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--deep);color:var(--tx);font-family:'Tiro Devanagari Hindi',serif;overflow-x:hidden;cursor:none;font-size:17px;line-height:1.7;}
